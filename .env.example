GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEET_NAME=Shipping Orders
ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3001
# Set to true to use built-in sample data instead of Google Sheets
USE_SAMPLE_DATA=false

# Frontend: base URL of the deployed API (leave empty for local dev via Vite proxy)
# Example: https://streamline-api.railway.app
VITE_API_URL=

# Backend: additional allowed CORS origin (optional)
CORS_ORIGIN=
